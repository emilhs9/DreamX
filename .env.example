# Runtime environment: development or production.
NODE_ENV=production

# Express port.
PORT=3000

# Public platform URL. Used in emails and generated links.
BASE_URL=https://dreamx.yourdomain.com

# Root domain for wildcard project subdomains. Example project: https://site.dream.x
PUBLIC_DOMAIN=dream.x

# GitHub OAuth app. Set callback URL to:
# https://your-domain.com/api/v1/github/oauth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=

# GitLab OAuth app. Set callback URL to:
# https://your-domain.com/api/v1/source/gitlab/oauth/callback
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_CALLBACK_URL=

# Optional DuckDNS values used by setup.sh on Linux Mint.
DOMAIN=dreamx.yourdomain.com
DUCKDNS_TOKEN=
DUCKDNS_SUBDOMAIN=
ACME_EMAIL=admin@example.com

# PostgreSQL connection string. Required in production.
DATABASE_URL=postgresql://launchpad:change_me@127.0.0.1:5432/launchpad

# Redis connection string for BullMQ queue support. Leave empty for local in-memory queue fallback.
REDIS_URL=redis://127.0.0.1:6379

# JWT secrets. Use long random values in production.
JWT_ACCESS_SECRET=change_me_access_64_chars
JWT_REFRESH_SECRET=change_me_refresh_64_chars
ADMIN_JWT_SECRET=change_me_admin_64_chars

# Separate /dream admin credentials.
ADMIN_USERNAME=dream
ADMIN_PASSWORD=dream

# Password hashing rounds.
BCRYPT_ROUNDS=12

# Access token lifetime.
ACCESS_TOKEN_TTL=15m

# Refresh token lifetime for normal sessions.
REFRESH_TOKEN_DAYS=7

# Refresh token lifetime when "Remember me" is checked.
REMEMBER_REFRESH_TOKEN_DAYS=90

# Maximum concurrent deployment builds when Redis/BullMQ is enabled.
DEPLOY_QUEUE_CONCURRENCY=3

# Maximum build command runtime in seconds.
BUILD_TIMEOUT_SECONDS=120

# Enable only when Node.js projects are isolated with containers or dedicated users.
ENABLE_NODE_RUNTIME=false

# Optional storage path overrides for Linux Mint/server installs.
DATA_DIR=
DEPLOYMENTS_DIR=
BUILDS_DIR=
UPLOADS_DIR=

# CORS whitelist. Comma-separated origins. Empty allows same-origin and server-to-server requests.
CORS_ORIGIN=https://dreamx.yourdomain.com

# SMTP settings for verification, reset password, announcements, and email blasts.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DreamX <no-reply@yourdomain.com>
